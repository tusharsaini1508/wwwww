# ------------------------------
# Frontend (Expo / Web)
# ------------------------------
# Public URL for your backend API. Safe to expose because it is not a secret.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_APP_NAME=Warehouse WMS

# ------------------------------
# Backend API
# ------------------------------
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:8081

# Neon Postgres connection string (server-side only, never expose in Expo client)
# Example format:
# postgresql://USER:PASSWORD@ep-xxxx-region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Auth/session settings for backend-issued tokens
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Optional logging
LOG_LEVEL=info

# ------------------------------
# First Setup (no defaults)
# ------------------------------
# Create the initial Super Admin through API after db:push:
# POST /api/setup/init
# {
#   "companyName": "Your Company",
#   "name": "Your Name",
#   "email": "you@example.com",
#   "password": "StrongPassword123!"
# }

# ------------------------------
# Optional MongoDB (only if you add Mongo for logs/events)
# ------------------------------
# MONGODB_URI=
